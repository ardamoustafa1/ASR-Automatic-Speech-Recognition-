# ─── Security ────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ASR_JWT_SECRET_KEY=change_this_to_a_secure_random_string_at_least_32_chars

# REQUIRED: Set a strong admin password (min 12 chars recommended)
ASR_ADMIN_PASSWORD=change_this_to_a_strong_password

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (Development)
ASR_DATABASE_URL=sqlite:///./data/asr_pro.db

# PostgreSQL (Production) — uncomment and fill in your credentials:
# ASR_DATABASE_URL=postgresql://user:password@localhost:5432/asr_pro

# ─── PostgreSQL Container Credentials (docker-compose) ───────────────────────
POSTGRES_USER=asr_user
POSTGRES_PASSWORD=change_this_strong_db_password
POSTGRES_DB=asr_pro

# ─── Cache / Queue ───────────────────────────────────────────────────────────
# Leave empty to use in-memory cache (development)
# For production, set to your Redis URL:
# ASR_REDIS_URL=redis://localhost:6379/0
ASR_REDIS_URL=

# ─── Webhooks ────────────────────────────────────────────────────────────────
# URL to receive alert payloads when a critical threshold is crossed (POST):
# ASR_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
ASR_WEBHOOK_URL=

# ─── CORS ────────────────────────────────────────────────────────────────────
ASR_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Testing ─────────────────────────────────────────────────────────────────
# Set to 1 to skip downloading heavy HuggingFace models during tests
ASR_TEST_NO_MODEL=0
